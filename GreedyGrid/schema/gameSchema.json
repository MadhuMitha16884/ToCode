{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["gameName", "grid", "rules", "winCondition"],
  "properties": {
    "gameName": {
      "type": "string"
    },
    "grid": {
      "type": "object",
      "properties": {
        "rows": { "type": "integer" },
        "columns": { "type": "integer" }
      }
    },
    "rules": {
      "type": "object"
    },
    "winCondition": {
      "type": "object"
    },
    "scoring": {
      "type": "object"
    }
  }
}